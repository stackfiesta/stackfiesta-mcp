{
  "name": "@stackfiesta/mcp",
  "version": "0.1.2",
  "mcpName": "dev.stackfiesta/stackfiesta-mcp",
  "description": "MCP server for StackFiesta — discover AI tools for game development",
  "type": "module",
  "bin": {
    "stackfiesta-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"fs.chmodSync('dist/index.js', 0o755)\"",
    "start": "node dist/index.js",
    "dev": "npx @modelcontextprotocol/inspector dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "stackfiesta",
    "game-development",
    "ai-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@posthog/mcp": "^0.5.1",
    "posthog-node": "^5.38.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
